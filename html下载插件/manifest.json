{
  "manifest_version": 3,
  "name": "HTML 页面下载器",
  "version": "1.0",
  "description": "一键下载当前网页的完整 HTML 源码为文件",
  "action": {
    "default_popup": "popup.html",
    "default_title": "下载 HTML"
  },
  "permissions": ["downloads"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
